# Copy to .env and set BRIDGE_TOKEN to a long random secret.
# Never commit .env.

BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=47821
BRIDGE_TOKEN=change-me-to-a-long-random-secret

# Directory for action logs (default: ./logs under project)
# BRIDGE_LOG_DIR=./logs

# Directory for screenshots (default: ./screenshots)
# BRIDGE_SCREENSHOT_DIR=./screenshots

# OpenClaw-readable copy of each screenshot (default: %USERPROFILE%\.openclaw\workspace\bridge-vision)
# BRIDGE_VISION_WORKSPACE=C:\Users\You\.openclaw\workspace\bridge-vision

# Optional: path to JSON file defining named keyboard macros.
# Each key maps to a list of keys for pyautogui.hotkey, e.g. {"my_macro": ["ctrl", "shift", "esc"]}
# BRIDGE_MACROS_PATH=./macros.example.json
